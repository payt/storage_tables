// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-docker-compose
{
  "name": "StorageTables",
  "dockerComposeFile": "docker-compose.yml",
  "service": "storage_tables",
  "workspaceFolder": "/app",

  "remoteUser": "${localEnv:DOCKER_CONTAINER_USER:runner}",

  "mounts": [
    "source=${localEnv:HOME}/.dev_container,target=${localEnv:DOCKER_CONTAINER_HOME:/home/runner}/.dev_container,readonly,type=bind"
  ],

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [5432],

  // Run commands after the container is created.
  "postCreateCommand": "cp -r ~/.dev_container/. ~; bundle install; bundle exec rails db:reset RAILS_ENV=test",

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "editorconfig.editorconfig",
        "shopify.ruby-lsp",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  }
}
